#!/bin/sh
# postinst — runs after .deb installation

set -e

# Create system user if it doesn't exist
if ! id -u turbineproxy >/dev/null 2>&1; then
    adduser --system --group --no-create-home \
            --home /usr/share/turbineproxy \
            --shell /usr/sbin/nologin \
            --comment "TurbineProxy daemon" \
            turbineproxy
fi

# Create log directory
install -d -o turbineproxy -g turbineproxy -m 0750 /var/log/turbineproxy

# Create config directory and place example if no config exists
install -d -m 0755 /etc/turbineproxy
if [ ! -f /etc/turbineproxy/turbineproxy.toml ]; then
    cp /etc/turbineproxy/turbineproxy.example.toml \
       /etc/turbineproxy/turbineproxy.toml
    echo "TurbineProxy: default config written to /etc/turbineproxy/turbineproxy.toml"
    echo "              Edit it before starting the service."
fi

# Reload systemd and enable the unit (but do NOT start automatically)
if [ -d /run/systemd/system ]; then
    systemctl daemon-reload || true
fi

exit 0
