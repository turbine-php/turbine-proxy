{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource scraping TurbineProxy /metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "title": "TurbineProxy",
  "uid": "turbineproxy-overview",
  "description": "TurbineProxy — query throughput, latency, pool health and replica lag",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "tags": ["mysql", "proxy", "turbineproxy"],
  "panels": [
    {
      "id": 1,
      "title": "Active client connections",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "turbineproxy_connections_active",
          "legendFormat": "active",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Query rate (QPS)",
      "type": "timeseries",
      "gridPos": { "x": 4, "y": 0, "w": 10, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(turbineproxy_queries_total{intent=\"read\"}[1m])",
          "legendFormat": "read",
          "refId": "A"
        },
        {
          "expr": "rate(turbineproxy_queries_total{intent=\"write\"}[1m])",
          "legendFormat": "write",
          "refId": "B"
        },
        {
          "expr": "rate(turbineproxy_queries_total{intent=\"other\"}[1m])",
          "legendFormat": "other",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "read" }, "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "write" }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 3,
      "title": "Query latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 14, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(turbineproxy_query_duration_seconds_bucket{intent=\"read\"}[1m]))",
          "legendFormat": "read p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(turbineproxy_query_duration_seconds_bucket{intent=\"read\"}[1m]))",
          "legendFormat": "read p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(turbineproxy_query_duration_seconds_bucket{intent=\"read\"}[1m]))",
          "legendFormat": "read p99",
          "refId": "C"
        },
        {
          "expr": "histogram_quantile(0.95, rate(turbineproxy_query_duration_seconds_bucket{intent=\"write\"}[1m]))",
          "legendFormat": "write p95",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      }
    },
    {
      "id": 4,
      "title": "Pool connections (idle / in-use)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 14, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "turbineproxy_pool_connections{state=\"idle\"}",
          "legendFormat": "{{backend}} {{role}} idle",
          "refId": "A"
        },
        {
          "expr": "turbineproxy_pool_connections{state=\"in_use\"}",
          "legendFormat": "{{backend}} {{role}} in_use",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        }
      }
    },
    {
      "id": 5,
      "title": "Replica lag",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 14, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "turbineproxy_replica_lag_seconds",
          "legendFormat": "{{backend}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Backend health",
      "type": "stat",
      "gridPos": { "x": 14, "y": 0, "w": 10, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "turbineproxy_backend_healthy",
          "legendFormat": "{{backend}} ({{role}})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "UNHEALTHY", "color": "red" }, "1": { "text": "HEALTHY", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Prometheus datasource"
      }
    ]
  }
}
